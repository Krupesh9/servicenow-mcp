# --- ServiceNow MCP configuration ---
# Copy this file to ".env" and fill in real values.

# Your ServiceNow instance URL (no trailing slash)
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com

# Authentication: basic | oauth | api_key
SERVICENOW_AUTH_TYPE=basic

# --- Basic auth (used when AUTH_TYPE=basic, or OAuth password grant) ---
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# --- OAuth (used when AUTH_TYPE=oauth) ---
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
# Optional — defaults to {INSTANCE_URL}/oauth_token.do
SERVICENOW_TOKEN_URL=

# --- API key (used when AUTH_TYPE=api_key) ---
SERVICENOW_API_KEY=
SERVICENOW_API_KEY_HEADER=X-ServiceNow-API-Key

# --- Optional ---
SERVICENOW_DEBUG=false
SERVICENOW_TIMEOUT=30

# Required only for the ExecuteScriptInclude tool
SCRIPT_EXECUTION_API_RESOURCE_PATH=

# Optional — limit which tool packages load. See servicenow-mcp docs for presets
# (e.g., service_desk, catalog_builder, platform_developer, full).
# MCP_TOOL_PACKAGE=full
